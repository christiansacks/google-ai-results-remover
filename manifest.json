{
  "manifest_version": 3,
  "name": "Google AI Results Remover",
  "version": "0.1.0",
  "description": "Hides AI Overviews, AI Mode, and other AI-generated blocks from Google Search results.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "google-ai-results-remover@erb.pw",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/*",
        "*://www.google.ad/*",
        "*://www.google.ae/*",
        "*://www.google.at/*",
        "*://www.google.be/*",
        "*://www.google.ca/*",
        "*://www.google.ch/*",
        "*://www.google.cl/*",
        "*://www.google.cn/*",
        "*://www.google.co.id/*",
        "*://www.google.co.il/*",
        "*://www.google.co.in/*",
        "*://www.google.co.jp/*",
        "*://www.google.co.kr/*",
        "*://www.google.co.nz/*",
        "*://www.google.co.th/*",
        "*://www.google.co.uk/*",
        "*://www.google.co.za/*",
        "*://www.google.com.ar/*",
        "*://www.google.com.au/*",
        "*://www.google.com.br/*",
        "*://www.google.com.mx/*",
        "*://www.google.com.sg/*",
        "*://www.google.com.tr/*",
        "*://www.google.com.tw/*",
        "*://www.google.cz/*",
        "*://www.google.de/*",
        "*://www.google.dk/*",
        "*://www.google.es/*",
        "*://www.google.fi/*",
        "*://www.google.fr/*",
        "*://www.google.gr/*",
        "*://www.google.hu/*",
        "*://www.google.ie/*",
        "*://www.google.it/*",
        "*://www.google.nl/*",
        "*://www.google.no/*",
        "*://www.google.pl/*",
        "*://www.google.pt/*",
        "*://www.google.ro/*",
        "*://www.google.ru/*",
        "*://www.google.se/*",
        "*://www.google.sk/*"
      ],
      "css": ["hide.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
